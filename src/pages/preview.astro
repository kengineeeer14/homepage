---
// デプロイ前のスマートフォン表示確認用URL
// http://localhost:4321/preview
const path = Astro.url.searchParams.get("path") ?? "/";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mobile Preview — ken.log</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; background: #0d1117; }
      body {
        display: flex;
        justify-content: center;
        align-items: flex-start;
      }
      iframe {
        border: none;
        width: 390px;
        height: 100vh;
        display: block;
      }
    </style>
  </head>
  <body>
    <iframe src={path}></iframe>
  </body>
</html>
