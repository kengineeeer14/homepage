{
  "name": "dev-log",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:pages": "sh scripts/kill-dev.sh && astro dev --host --port 4322 & sleep 3 && npx wrangler pages dev --proxy 4322 --port 4321 --ip 0.0.0.0 --kv VISITS_KV --persist-to .wrangler/state --compatibility-date=2026-04-08",
    "build": "astro build && cp -r functions dist/functions",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.2",
    "katex": "^0.16.44",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  }
}
