---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | ken.log`}
  description={post.data.description}
  meta={{ type: "post", date: post.data.date, tags: post.data.tags }}
>
  <article style="padding: 2rem 0;">
    <!-- パンくず -->
    <nav
      style="margin-bottom: 2rem; font-size: 0.85rem; color: #8b949e; font-family: 'JetBrains Mono', monospace;"
    >
      <a href="/blog" style="color: #58a6ff; text-decoration: none;">blog</a>
      <span style="margin: 0 0.5rem;">/</span>
      <span>{post.data.title}</span>
    </nav>

    <!-- ヘッダー -->
    <header
      style="margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #30363d;"
    >
      <h1
        style="font-size: 2rem; font-weight: 700; color: #e6edf3; margin-bottom: 1rem; line-height: 1.3;"
      >
        {post.data.title}
      </h1>
      <div
        style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;"
      >
        <time
          style="color: #8b949e; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;"
        >
          {post.data.date.toISOString().slice(0, 10)}
        </time>
        {
          post.data.tags.length > 0 && (
            <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
              {post.data.tags.map((tag) => (
                <a
                  href={`/blog?tag=${tag}`}
                  style="padding: 0.15rem 0.5rem; background-color: rgba(88,166,255,0.1); color: #58a6ff; border-radius: 4px; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; text-decoration: none;"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <!-- 本文 -->
    <div class="prose">
      <Content />
    </div>

    <!-- リアクション -->
    <div
      style="margin-top: 3rem; padding: 1.5rem; border: 1px solid #30363d; border-radius: 8px; background: #161b22; position: relative;"
    >
      <p style="font-size: 0.85rem; color: #8b949e; margin: 0 0 1rem 0; font-family: 'JetBrains Mono', monospace;">
        この記事はいかがでしたか？
      </p>
      <!-- 既存リアクション一覧 -->
      <div id="reaction-list" style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
        <!-- リアクションピルはJSで動的に挿入 -->
        <button
          id="add-reaction-btn"
          title="バナナを送る"
          style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.3rem 0.65rem; background: #0d1117; border: 1px solid #30363d; border-radius: 20px; color: #8b949e; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; cursor: pointer; transition: border-color 0.2s, color 0.2s, box-shadow 0.2s; flex-shrink: 0;"
          onmouseenter="this.style.borderColor='#58a6ff';this.style.color='#58a6ff';this.style.boxShadow='0 0 0 3px rgba(88,166,255,0.15)'"
          onmouseleave="this.style.borderColor='#30363d';this.style.color='#8b949e';this.style.boxShadow='none'"
        >
          <span>🍌</span>
        </button>
      </div>
    </div>

    <!-- コメント -->
    <div style="margin-top: 3rem;">

      <!-- セクションヘッダー -->
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <span style="font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; color: #8b949e; font-family: 'JetBrains Mono', monospace; text-transform: uppercase;">Comments</span>
        <span id="comment-count" style="font-size: 0.7rem; color: #8b949e; font-family: 'JetBrains Mono', monospace;"></span>
        <div style="flex: 1; height: 1px; background: #21262d;"></div>
      </div>

      <!-- コメント一覧 -->
      <div id="comment-list" style="display: flex; flex-direction: column; gap: 0;"></div>

      <!-- 投稿フォーム -->
      <div style="margin-top: 1.5rem;">
        <div style="font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; color: #8b949e; font-family: 'JetBrains Mono', monospace; text-transform: uppercase; margin-bottom: 0.6rem;">New Comment</div>
        <textarea
          id="comment-content"
          rows="3"
          placeholder="コメントを入力…"
          maxlength="1000"
          style="display: block; width: 100%; padding: 0.65rem 0.75rem; background: #0d1117; border: 1px solid #30363d; border-radius: 4px; color: #e6edf3; font-size: 0.875rem; font-family: inherit; line-height: 1.6; outline: none; resize: vertical; box-sizing: border-box; transition: border-color 0.15s;"
          onfocus="this.style.borderColor='#58a6ff'"
          onblur="this.style.borderColor='#30363d'"
        ></textarea>
        <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 0.5rem;">
          <span id="comment-form-error" style="font-size: 0.8rem; color: #f85149; font-family: 'JetBrains Mono', monospace;"></span>
          <button
            id="comment-submit-btn"
            style="padding: 0.4rem 1.1rem; background: #161b22; border: 1px solid #30363d; border-radius: 4px; color: #e6edf3; font-size: 0.8rem; font-family: 'JetBrains Mono', monospace; cursor: pointer; transition: border-color 0.15s, color 0.15s;"
            onmouseenter="this.style.borderColor='#58a6ff';this.style.color='#58a6ff'"
            onmouseleave="this.style.borderColor='#30363d';this.style.color='#e6edf3'"
          >送信</button>
        </div>
      </div>
    </div>

    <!-- フッターナビ -->
    <div
      style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #30363d;"
    >
      <a
        href="/blog"
        style="color: #58a6ff; text-decoration: none; font-size: 0.9rem;"
        >← 記事一覧に戻る</a
      >
    </div>
  </article>

<script define:vars={{ postId: post.id }}>
  const BANANA = "🍌";

  const storageKey = `reactions2:${postId}`;
  const countCacheKey = `reaction-counts2:${postId}`;
  const reacted = new Set(JSON.parse(localStorage.getItem(storageKey) ?? "[]"));

  const list = document.getElementById("reaction-list");
  const addBtn = document.getElementById("add-reaction-btn");

  // バナナボタンをクリックで直接送信
  addBtn.addEventListener("click", () => { sendReaction(BANANA); });

  // 自分または誰かがバナナをあげていたらボタンを非表示
  function updateAddBtn() {
    const counts = JSON.parse(localStorage.getItem(countCacheKey) ?? "{}");
    const bananaCount = counts[BANANA] ?? 0;
    addBtn.style.display = (reacted.has(BANANA) || bananaCount > 0) ? "none" : "inline-flex";
  }
  updateAddBtn();

  // リアクションピルを作成・更新（count=0なら削除）
  function upsertPill(emoji, count) {
    const id = `pill-${[...emoji].map(c => c.codePointAt(0).toString(16)).join("-")}`;
    let pill = document.getElementById(id);
    if (count === 0) {
      pill?.remove();
      return;
    }
    if (!pill) {
      pill = document.createElement("button");
      pill.id = id;
      pill.style.cssText = "display:inline-flex; align-items:center; gap:0.4rem; padding:0.3rem 0.7rem; background:#0d1117; border:1px solid #30363d; border-radius:20px; color:#e6edf3; font-size:0.9rem; cursor:pointer; transition:border-color 0.2s, background 0.2s, box-shadow 0.2s;";
      pill.addEventListener("mouseenter", () => {
        if (!reacted.has(emoji)) pill.style.boxShadow = "0 0 0 3px rgba(88,166,255,0.12)";
      });
      pill.addEventListener("mouseleave", () => {
        if (!reacted.has(emoji)) pill.style.boxShadow = "none";
      });
      pill.addEventListener("click", () => sendReaction(emoji));
      list.insertBefore(pill, addBtn);
    }
    const active = reacted.has(emoji);
    pill.style.borderColor = active ? "#58a6ff" : "#30363d";
    pill.style.background = active ? "rgba(88,166,255,0.15)" : "#0d1117";
    pill.style.boxShadow = active ? "0 0 0 3px rgba(88,166,255,0.1)" : "none";
    pill.innerHTML = `<span>${emoji}</span><span style="font-size:0.78rem; color:${active ? "#58a6ff" : "#8b949e"}; font-family:'JetBrains Mono',monospace;">${count}</span>`;
  }

  // リクエスト中の絵文字を管理（多重送信防止）
  const inFlight = new Set();

  // リアクション送信（トグル対応）
  async function sendReaction(emoji) {
    if (inFlight.has(emoji)) return;
    inFlight.add(emoji);
    const removing = reacted.has(emoji);
    // 楽観的UI更新：サーバーレスポンスを待たずに即時反映
    const counts = JSON.parse(localStorage.getItem(countCacheKey) ?? "{}");
    const prevCount = counts[emoji] ?? 0;
    const optimisticCount = removing ? prevCount - 1 : prevCount + 1;
    if (removing) {
      reacted.delete(emoji);
    } else {
      reacted.add(emoji);
    }
    localStorage.setItem(storageKey, JSON.stringify([...reacted]));
    upsertPill(emoji, optimisticCount);
    updateAddBtn();
    // リクエスト中は視覚的に無効化
    const targetEl = emoji === BANANA
      ? addBtn
      : document.getElementById(`pill-${[...emoji].map(c => c.codePointAt(0).toString(16)).join("-")}`);
    if (targetEl) targetEl.style.opacity = "0.5";
    try {
      const res = await fetch(`/api/reactions?post=${encodeURIComponent(postId)}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ emoji, remove: removing }),
      });
      const data = await res.json();
      // サーバーの実際のカウントで更新
      if (data.count === 0) {
        delete counts[emoji];
      } else {
        counts[emoji] = data.count;
      }
      localStorage.setItem(countCacheKey, JSON.stringify(counts));
      upsertPill(emoji, data.count);
    } catch {
      // エラー時は元の状態に戻す
      if (removing) {
        reacted.add(emoji);
      } else {
        reacted.delete(emoji);
      }
      localStorage.setItem(storageKey, JSON.stringify([...reacted]));
      upsertPill(emoji, prevCount);
      updateAddBtn();
    } finally {
      inFlight.delete(emoji);
      if (targetEl) targetEl.style.opacity = "1";
    }
  }

  // 初期ロード：まずキャッシュを表示してからサーバーで更新
  const cachedCounts = JSON.parse(localStorage.getItem(countCacheKey) ?? "{}");
  for (const [emoji, count] of Object.entries(cachedCounts)) {
    upsertPill(emoji, count);
  }
  updateAddBtn();

  fetch(`/api/reactions?post=${encodeURIComponent(postId)}`)
    .then(r => r.json())
    .then(data => {
      localStorage.setItem(countCacheKey, JSON.stringify(data));
      // サーバーにないピルを削除
      for (const emoji of Object.keys(cachedCounts)) {
        if (!(emoji in data)) upsertPill(emoji, 0);
      }
      for (const [emoji, count] of Object.entries(data)) {
        upsertPill(emoji, count);
      }
      updateAddBtn();
    })
    .catch(() => {});
</script>

<script define:vars={{ postId: post.id.replace(/\.[^/.]+$/, "") }}>
  // コメント機能
  const tokenStoreKey = `comment-tokens:${postId}`;
  const myTokens = JSON.parse(localStorage.getItem(tokenStoreKey) ?? "{}");

  const commentList = document.getElementById("comment-list");
  const commentCount = document.getElementById("comment-count");

  function saveTokens() {
    localStorage.setItem(tokenStoreKey, JSON.stringify(myTokens));
  }

  function formatDate(iso) {
    const d = new Date(iso);
    const pad = (n) => String(n).padStart(2, "0");
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  function escapeHtml(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function renderComment(comment, index) {
    const isMine = !!myTokens[comment.id];
    const idx = String(index).padStart(3, "0");
    const el = document.createElement("div");
    el.id = `comment-${comment.id}`;
    el.style.cssText = `padding: 0.85rem 0.9rem; border-left: 2px solid ${isMine ? "#58a6ff" : "#21262d"}; margin-bottom: 0.75rem; background: ${isMine ? "rgba(88,166,255,0.03)" : "transparent"};`;
    el.innerHTML = `
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 0.6rem;">
          <span style="font-size: 0.72rem; font-weight: 700; color: ${isMine ? "#58a6ff" : "#484f58"}; font-family: 'JetBrains Mono', monospace;">#${idx}</span>
          <time style="font-size: 0.72rem; color: #8b949e; font-family: 'JetBrains Mono', monospace;">${formatDate(comment.timestamp)}</time>
          ${isMine ? '<span style="font-size: 0.68rem; color: #58a6ff; border: 1px solid rgba(88,166,255,0.4); border-radius: 2px; padding: 0.05rem 0.35rem; font-family: \'JetBrains Mono\', monospace;">self</span>' : ""}
          ${comment.edited ? '<span style="font-size: 0.68rem; color: #484f58; font-family: \'JetBrains Mono\', monospace;">edited</span>' : ""}
        </div>
        ${isMine ? `
          <div style="display: flex; gap: 0.75rem;">
            <button class="edit-btn" data-id="${comment.id}" style="background: none; border: none; color: #484f58; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; cursor: pointer; padding: 0; text-decoration: underline; text-underline-offset: 2px;" onmouseenter="this.style.color='#8b949e'" onmouseleave="this.style.color='#484f58'">編集</button>
            <button class="delete-btn" data-id="${comment.id}" style="background: none; border: none; color: #484f58; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; cursor: pointer; padding: 0; text-decoration: underline; text-underline-offset: 2px;" onmouseenter="this.style.color='#f85149'" onmouseleave="this.style.color='#484f58'">削除</button>
          </div>
        ` : ""}
      </div>
      <p class="comment-body" style="color: #c9d1d9; font-size: 0.875rem; line-height: 1.7; margin: 0; white-space: pre-wrap; word-break: break-word;">${escapeHtml(comment.content)}</p>
      ${isMine ? `
        <div class="edit-form" style="display: none; margin-top: 0.75rem;">
          <textarea class="edit-textarea" rows="3" style="width: 100%; padding: 0.5rem 0.65rem; background: #0d1117; border: 1px solid #58a6ff; border-radius: 4px; color: #e6edf3; font-size: 0.875rem; font-family: inherit; outline: none; resize: vertical; box-sizing: border-box; line-height: 1.6;">${escapeHtml(comment.content)}</textarea>
          <div style="display: flex; gap: 0.75rem; margin-top: 0.4rem;">
            <button class="edit-save-btn" data-id="${comment.id}" style="padding: 0.3rem 0.8rem; background: #161b22; border: 1px solid #238636; border-radius: 4px; color: #3fb950; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; cursor: pointer;" onmouseenter="this.style.background='rgba(63,185,80,0.1)'" onmouseleave="this.style.background='#161b22'">保存</button>
            <button class="edit-cancel-btn" style="padding: 0.3rem 0.8rem; background: none; border: 1px solid #30363d; border-radius: 4px; color: #8b949e; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; cursor: pointer;">キャンセル</button>
          </div>
        </div>
      ` : ""}
    `;

    // 編集ボタン
    el.querySelector(".edit-btn")?.addEventListener("click", () => {
      el.querySelector(".edit-form").style.display = "block";
      el.querySelector(".edit-btn").style.display = "none";
      el.querySelector(".delete-btn").style.display = "none";
    });

    // 編集キャンセル
    el.querySelector(".edit-cancel-btn")?.addEventListener("click", () => {
      el.querySelector(".edit-form").style.display = "none";
      el.querySelector(".edit-btn").style.display = "";
      el.querySelector(".delete-btn").style.display = "";
    });

    // 編集保存
    el.querySelector(".edit-save-btn")?.addEventListener("click", async (e) => {
      const id = e.target.dataset.id;
      const newContent = el.querySelector(".edit-textarea").value.trim();
      if (!newContent) return;
      const token = myTokens[id];
      try {
        const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}&id=${encodeURIComponent(id)}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, content: newContent }),
        });
        if (!res.ok) throw new Error();
        const updated = await res.json();
        el.querySelector(".comment-body").textContent = updated.content;
        el.querySelector(".edit-textarea").value = updated.content;
        el.querySelector(".edit-form").style.display = "none";
        el.querySelector(".edit-btn").style.display = "";
        el.querySelector(".delete-btn").style.display = "";
        // 「編集済み」バッジを追加
        if (!el.querySelector(".edited-badge")) {
          const badge = document.createElement("span");
          badge.className = "edited-badge";
          badge.textContent = "(編集済み)";
          badge.style.cssText = "font-size: 0.7rem; color: #8b949e;";
          el.querySelector(".edit-btn").before(badge, el.querySelector(".edit-btn").previousSibling);
        }
      } catch {
        alert("編集に失敗しました。");
      }
    });

    // 削除ボタン
    el.querySelector(".delete-btn")?.addEventListener("click", async (e) => {
      if (!confirm("このコメントを削除しますか？")) return;
      const id = e.target.dataset.id;
      const token = myTokens[id];
      try {
        const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}&id=${encodeURIComponent(id)}`, {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token }),
        });
        if (!res.ok) throw new Error();
        el.remove();
        delete myTokens[id];
        saveTokens();
        updateCount(-1);
      } catch {
        alert("削除に失敗しました。");
      }
    });

    return el;
  }

  const INITIAL_COMMENT_COUNT = 3;
  let expanded = localStorage.getItem(`comment-expanded:${postId}`) === "true";

  let currentCount = 0;
  function updateCount(delta) {
    currentCount += delta;
    commentCount.textContent = `n = ${currentCount}`;
  }

  // コメント一覧を取得
  async function loadComments() {
    try {
      const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}`);
      const comments = await res.json();
      currentCount = comments.length;
      commentCount.textContent = `n = ${currentCount}`;
      commentList.innerHTML = "";
      if (comments.length === 0) {
        const empty = document.createElement("p");
        empty.id = "comment-empty";
        empty.style.cssText = "color: #484f58; font-size: 0.8rem; padding: 0.5rem 0; font-family: 'JetBrains Mono', monospace; margin: 0;";
        empty.textContent = "n = 0";
        commentList.appendChild(empty);
      } else {
        const btnStyle = "margin-top: 0.25rem; margin-bottom: 0.5rem; background: none; border: none; color: #484f58; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; cursor: pointer; padding: 0; text-decoration: underline; text-underline-offset: 2px;";
        const reversed = [...comments].reverse();
        if (!expanded) {
          const visible = reversed.slice(0, INITIAL_COMMENT_COUNT);
          for (let i = 0; i < visible.length; i++) {
            commentList.appendChild(renderComment(visible[i], comments.length - i));
          }
          if (comments.length > INITIAL_COMMENT_COUNT) {
            const btn = document.createElement("button");
            btn.style.cssText = btnStyle;
            btn.textContent = `+ ${comments.length - INITIAL_COMMENT_COUNT} older`;
            btn.addEventListener("mouseenter", () => { btn.style.color = "#8b949e"; });
            btn.addEventListener("mouseleave", () => { btn.style.color = "#484f58"; });
            btn.addEventListener("click", () => {
              expanded = true;
              localStorage.setItem(`comment-expanded:${postId}`, "true");
              loadComments();
            });
            commentList.appendChild(btn);
          }
        } else {
          for (let i = 0; i < reversed.length; i++) {
            commentList.appendChild(renderComment(reversed[i], comments.length - i));
          }
          if (comments.length > INITIAL_COMMENT_COUNT) {
            const btn = document.createElement("button");
            btn.style.cssText = btnStyle;
            btn.textContent = `- show less`;
            btn.addEventListener("mouseenter", () => { btn.style.color = "#8b949e"; });
            btn.addEventListener("mouseleave", () => { btn.style.color = "#484f58"; });
            btn.addEventListener("click", () => {
              expanded = false;
              localStorage.setItem(`comment-expanded:${postId}`, "false");
              loadComments();
            });
            commentList.appendChild(btn);
          }
        }
      }
    } catch {}
  }

  loadComments();
  setInterval(loadComments, 15000);

  // テキストエリア自動リサイズ
  const contentInput = document.getElementById("comment-content");
  contentInput.addEventListener("input", () => {
    contentInput.style.height = "auto";
    contentInput.style.height = contentInput.scrollHeight + "px";
  });

  // コメント投稿フォーム
  const submitBtn = document.getElementById("comment-submit-btn");
  const formError = document.getElementById("comment-form-error");

  submitBtn.addEventListener("click", async () => {
    const content = contentInput.value.trim();
    formError.textContent = "";
    if (!content) { formError.textContent = "コメントを入力してください"; return; }
    submitBtn.disabled = true;
    submitBtn.textContent = "送信中...";
    try {
      const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ content }),
      });
      const data = await res.json();
      if (!res.ok) {
        formError.textContent = data.error ?? "送信に失敗しました";
      } else {
        const tokens = JSON.parse(localStorage.getItem(tokenStoreKey) ?? "{}");
        tokens[data.id] = data.token;
        localStorage.setItem(tokenStoreKey, JSON.stringify(tokens));
        myTokens[data.id] = data.token;
        contentInput.value = "";
        await loadComments();
      }
    } catch {
      formError.textContent = "送信に失敗しました";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "投稿する";
    }
  });
</script>
</BaseLayout>
