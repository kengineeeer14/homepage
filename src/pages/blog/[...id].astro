---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | ken.log`}
  description={post.data.description}
>
  <article style="padding: 2rem 0;">
    <!-- パンくず -->
    <nav
      style="margin-bottom: 2rem; font-size: 0.85rem; color: #8b949e; font-family: 'JetBrains Mono', monospace;"
    >
      <a href="/blog" style="color: #58a6ff; text-decoration: none;">blog</a>
      <span style="margin: 0 0.5rem;">/</span>
      <span>{post.id}</span>
    </nav>

    <!-- ヘッダー -->
    <header
      style="margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #30363d;"
    >
      <h1
        style="font-size: 2rem; font-weight: 700; color: #e6edf3; margin-bottom: 1rem; line-height: 1.3;"
      >
        {post.data.title}
      </h1>
      <div
        style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;"
      >
        <time
          style="color: #8b949e; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;"
        >
          {post.data.date.toISOString().slice(0, 10)}
        </time>
        {
          post.data.tags.length > 0 && (
            <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
              {post.data.tags.map((tag) => (
                <a
                  href={`/blog?tag=${tag}`}
                  style="padding: 0.15rem 0.5rem; background-color: rgba(88,166,255,0.1); color: #58a6ff; border-radius: 4px; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; text-decoration: none;"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <!-- 本文 -->
    <div class="prose">
      <Content />
    </div>

    <!-- フッターナビ -->
    <div
      style="margin-top: 4rem; padding-top: 1.5rem; border-top: 1px solid #30363d;"
    >
      <a
        href="/blog"
        style="color: #58a6ff; text-decoration: none; font-size: 0.9rem;"
        >← 記事一覧に戻る</a
      >
    </div>
  </article>
</BaseLayout>
