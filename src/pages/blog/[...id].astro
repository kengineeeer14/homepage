---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | ken.log`}
  description={post.data.description}
  meta={{ type: "post", date: post.data.date, tags: post.data.tags }}
>
  <article style="padding: 2rem 0;">
    <!-- パンくず -->
    <nav
      style="margin-bottom: 2rem; font-size: 0.85rem; color: #8b949e; font-family: 'JetBrains Mono', monospace;"
    >
      <a href="/blog" style="color: #58a6ff; text-decoration: none;">blog</a>
      <span style="margin: 0 0.5rem;">/</span>
      <span>{post.data.title}</span>
    </nav>

    <!-- ヘッダー -->
    <header
      style="margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #30363d;"
    >
      <h1
        style="font-size: 2rem; font-weight: 700; color: #e6edf3; margin-bottom: 1rem; line-height: 1.3;"
      >
        {post.data.title}
      </h1>
      <div
        style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;"
      >
        <time
          style="color: #8b949e; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;"
        >
          {post.data.date.toISOString().slice(0, 10)}
        </time>
        {
          post.data.tags.length > 0 && (
            <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
              {post.data.tags.map((tag) => (
                <a
                  href={`/blog?tag=${tag}`}
                  style="padding: 0.15rem 0.5rem; background-color: rgba(88,166,255,0.1); color: #58a6ff; border-radius: 4px; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; text-decoration: none;"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <!-- 本文 -->
    <div class="prose">
      <Content />
    </div>

    <!-- リアクション -->
    <div
      style="margin-top: 3rem; padding: 1.5rem; border: 1px solid #30363d; border-radius: 8px; background: #161b22; position: relative;"
    >
      <p style="font-size: 0.85rem; color: #8b949e; margin: 0 0 1rem 0; font-family: 'JetBrains Mono', monospace;">
        この記事はいかがでしたか？
      </p>
      <!-- 既存リアクション一覧 -->
      <div id="reaction-list" style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
        <!-- リアクションピルはJSで動的に挿入 -->
        <button
          id="add-reaction-btn"
          title="リアクションを追加"
          style="display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.3rem 0.65rem; background: #0d1117; border: 1px solid #30363d; border-radius: 20px; color: #8b949e; font-size: 0.78rem; font-family: 'JetBrains Mono', monospace; cursor: pointer; transition: border-color 0.2s, color 0.2s, box-shadow 0.2s; flex-shrink: 0;"
          onmouseenter="this.style.borderColor='#58a6ff';this.style.color='#58a6ff';this.style.boxShadow='0 0 0 3px rgba(88,166,255,0.15)'"
          onmouseleave="this.style.borderColor='#30363d';this.style.color='#8b949e';this.style.boxShadow='none'"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="5.5" cy="6.5" r="1" fill="currentColor"/>
            <circle cx="10.5" cy="6.5" r="1" fill="currentColor"/>
            <path d="M5.5 10.5 C6.2 12 9.8 12 10.5 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 3v2.5M10.75 4.25h2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          <span>反応する</span>
        </button>
      </div>

      <!-- 絵文字ピッカー -->
      <div
        id="emoji-picker"
        style="display: none; position: absolute; z-index: 100; bottom: calc(100% + 8px); left: 0; background: #0d1117; border: 1px solid #30363d; border-radius: 8px; padding: 0.75rem; box-shadow: 0 8px 24px rgba(0,0,0,0.5); width: min(340px, 90vw);"
      >
        <!-- デフォルト3つ -->
        <div id="emoji-quick" style="display: flex; gap: 4px; margin-bottom: 0.5rem;"></div>
        <!-- 展開ボタン -->
        <button id="emoji-expand-btn" style="width: 100%; background: none; border: 1px solid #30363d; border-radius: 4px; color: #8b949e; font-size: 0.78rem; padding: 0.25rem; cursor: pointer; font-family: 'JetBrains Mono', monospace;">もっと見る ▾</button>
        <!-- 全絵文字グリッド（折りたたみ） -->
        <div id="emoji-grid" style="display: none; grid-template-columns: repeat(8, 1fr); gap: 2px; margin-top: 0.5rem; max-height: 240px; overflow-y: auto;"></div>
      </div>
    </div>

    <!-- コメント -->
    <div style="margin-top: 2rem;">
      <h2
        style="font-size: 1rem; font-weight: 600; color: #e6edf3; margin-bottom: 1.5rem; font-family: 'JetBrains Mono', monospace; display: flex; align-items: center; gap: 0.5rem;"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0; color:#8b949e;">
          <path d="M1 2.75C1 1.784 1.784 1 2.75 1h10.5c.966 0 1.75.784 1.75 1.75v7.5A1.75 1.75 0 0 1 13.25 12H9.06l-2.573 2.573A1.458 1.458 0 0 1 4 13.543V12H2.75A1.75 1.75 0 0 1 1 10.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h2a.75.75 0 0 1 .75.75v2.19l2.72-2.72a.749.749 0 0 1 .53-.22h4.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"/>
        </svg>
        コメント
        <span id="comment-count" style="font-size: 0.8rem; color: #8b949e; font-weight: 400;"></span>
      </h2>

      <!-- コメントリスト -->
      <div id="comment-list" style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;"></div>

      <!-- コメントフォーム -->
      <div style="padding: 1.25rem; border: 1px solid #30363d; border-radius: 8px; background: #161b22;">
        <p style="font-size: 0.85rem; color: #8b949e; margin: 0 0 1rem 0; font-family: 'JetBrains Mono', monospace;">
          コメントを書く
        </p>
        <form id="comment-form" style="display: flex; flex-direction: column; gap: 0.75rem;">
          <input
            id="comment-author"
            type="text"
            placeholder="お名前（必須・最大50文字）"
            maxlength="50"
            required
            style="padding: 0.5rem 0.75rem; background: #0d1117; border: 1px solid #30363d; border-radius: 6px; color: #e6edf3; font-size: 0.875rem; font-family: inherit; outline: none; transition: border-color 0.2s;"
            onfocus="this.style.borderColor='#58a6ff'"
            onblur="this.style.borderColor='#30363d'"
          />
          <textarea
            id="comment-content"
            placeholder="コメントを入力...（最大1000文字）"
            maxlength="1000"
            required
            rows="4"
            style="padding: 0.5rem 0.75rem; background: #0d1117; border: 1px solid #30363d; border-radius: 6px; color: #e6edf3; font-size: 0.875rem; font-family: inherit; outline: none; resize: vertical; transition: border-color 0.2s;"
            onfocus="this.style.borderColor='#58a6ff'"
            onblur="this.style.borderColor='#30363d'"
          ></textarea>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <button
              type="submit"
              id="comment-submit-btn"
              style="padding: 0.45rem 1rem; background: #238636; border: 1px solid #2ea043; border-radius: 6px; color: #fff; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace; cursor: pointer; transition: background 0.2s;"
              onmouseenter="this.style.background='#2ea043'"
              onmouseleave="this.style.background='#238636'"
            >
              送信
            </button>
            <span id="comment-form-error" style="font-size: 0.8rem; color: #f85149; display: none;"></span>
          </div>
        </form>
      </div>
    </div>

    <!-- フッターナビ -->
    <div
      style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #30363d;"
    >
      <a
        href="/blog"
        style="color: #58a6ff; text-decoration: none; font-size: 0.9rem;"
        >← 記事一覧に戻る</a
      >
    </div>
  </article>

<script define:vars={{ postId: post.id }}>
  const EMOJIS = [
    // 笑顔・表情
    "😀","😃","😄","😁","😆","😅","🤣","😂",
    "🙂","🙃","😉","😊","😇","🥰","😍","🤩",
    "😘","😋","😛","😜","🤪","😝","🤑","🤗",
    "🤔","🤨","😐","😑","😶","😏","😒","🙄",
    "😬","😌","😔","😪","🤤","😴","😷","🤒",
    "🤢","🤮","🤧","🥵","🥶","😵","🤯","🥳",
    "😎","🤓","🧐","😕","😟","😮","😱","😭",
    "😤","😡","😠","🤬","😈","👿","💀","🤡",
    // 手・体
    "👋","🤚","✋","🖐️","🖖","👌","✌️","🤞",
    "🤟","🤘","🤙","👍","👎","👏","🙌","🙏",
    "💪","🤝","🫶","🫂","👀","💋","✍️","💅",
    // 動物
    "🐶","🐱","🐭","🐹","🐰","🦊","🐻","🐼",
    "🐨","🐯","🦁","🐮","🐷","🐸","🐵","🙈",
    "🐔","🐧","🐦","🦆","🦅","🦉","🦇","🐺",
    "🐴","🦄","🐝","🦋","🐛","🐌","🐞","🐜",
    "🐢","🐍","🦎","🐙","🦑","🐟","🐬","🐋",
    "🦈","🐊","🦏","🐘","🦒","🦘","🦬","🐃",
    "🦍","🦧","🐪","🦓","🐅","🐆","🐕","🐈",
    "🐓","🦃","🦚","🦜","🦢","🦩","🕊️","🐇",
    // 食べ物
    "🍎","🍐","🍊","🍋","🍌","🍉","🍇","🍓",
    "🫐","🍒","🍑","🥭","🍍","🥥","🥝","🍅",
    "🍆","🥑","🥦","🥕","🌽","🌶️","🥒","🧄",
    "🍕","🍔","🍟","🌭","🌮","🌯","🥪","🍜",
    "🍣","🍱","🍛","🍩","🍰","🎂","🍫","🍭",
    "🍿","🧁","🍪","🍯","🥐","🧀","🥚","🍳",
    "☕","🍵","🧃","🥤","🧋","🍺","🍷","🥂",
    "🍸","🍹","🍾","🧊","🫖","🥛","🍼","🍻",
    // 乗り物・場所
    "🚗","🚕","🚙","🚌","🏎️","🚓","🚑","🚒",
    "🚲","🛴","🛹","🛻","✈️","🚀","🚁","🛸",
    "🚢","⛵","🚤","🛥️","🏔️","🌋","🏕️","🏖️",
    "🏝️","🏠","🏢","🏛️","🏰","🗼","🗽","⛩️",
    "🌉","🌆","🌇","🌃","🌌","🌅","🌄","🎑",
    // スポーツ・活動
    "⚽","🏀","🏈","⚾","🎾","🏐","🏉","🎱",
    "🏒","⛳","🎣","🥊","🥋","🎽","🛷","⛸️",
    "🏋️","🤸","🏄","🚣","🧘","⛹️","🤾","🏇",
    "🏆","🥇","🥈","🥉","🎖️","🏅","🎪","🎠",
    // 音楽・エンタメ
    "🎮","🕹️","🎲","♟️","🃏","🎴","🎰","🎯",
    "🎨","🎭","🎬","🎤","🎧","🎼","🎵","🎶",
    "🎷","🎸","🎹","🎺","🎻","🥁","🪘","🎙️",
    // テクノロジー・道具
    "💻","🖥️","🖨️","⌨️","🖱️","📱","📲","☎️",
    "📺","📷","📸","📹","🎥","📡","🔋","🔌",
    "💡","🔦","🕯️","💰","💳","💸","📈","📉",
    "📝","📋","📌","📍","📎","✂️","🔒","🔓",
    "🔑","🗝️","🔨","🔧","🔩","⚙️","🛠️","🔭",
    "🔬","💊","🩺","🩹","🧪","⚗️","🔮","🧿",
    "📚","📖","📰","📜","📃","📄","📑","🗒️",
    "✉️","📧","📨","📩","📬","📭","📮","🗳️",
    // 自然・天気
    "🌍","🌎","🌏","🌙","⭐","🌟","💫","✨",
    "⚡","🌈","☁️","🌤️","🌧️","🌩️","❄️","🔥",
    "💧","🌊","🌱","🌿","☘️","🍀","🌷","🌹",
    "🥀","🌺","🌸","🌼","🌻","🌞","🍄","🌾",
    "🍁","🍂","🍃","🌵","🎋","🎍","🪨","🌴",
    // ハート・シンボル
    "❤️","🧡","💛","💚","💙","💜","🖤","🤍",
    "🤎","💔","💕","💞","💓","💗","💖","💘",
    "💝","💟","☮️","✝️","☪️","🕉️","☯️","✡️",
    "♻️","✅","❌","⭕","⚠️","💯","🔞","🚫",
    "🔴","🟠","🟡","🟢","🔵","🟣","⚫","⚪",
    // お祝い・イベント
    "🎁","🎀","🎗️","🎟️","🎫","🎈","🎃","🎄",
    "🎆","🎇","🧨","🎉","🎊","🎋","🎍","🎑",
    "🪄","🎩","👑","💎","🪆","🪅","🃏","🀄",
  ];

  const QUICK_EMOJIS = ["👍", "❤️", "💡"];

  const storageKey = `reactions2:${postId}`;
  const reacted = new Set(JSON.parse(localStorage.getItem(storageKey) ?? "[]"));

  const list = document.getElementById("reaction-list");
  const addBtn = document.getElementById("add-reaction-btn");
  const picker = document.getElementById("emoji-picker");
  const quickRow = document.getElementById("emoji-quick");
  const grid = document.getElementById("emoji-grid");
  const expandBtn = document.getElementById("emoji-expand-btn");

  // クイック絵文字ボタンを構築
  function makeEmojiBtn(emoji, large) {
    const btn = document.createElement("button");
    btn.textContent = emoji;
    btn.style.cssText = `background:none; border:none; cursor:pointer; font-size:${large ? "1.6rem" : "1.25rem"}; padding:0.3rem; border-radius:4px; transition:background 0.1s; line-height:1;`;
    btn.addEventListener("mouseenter", () => { btn.style.background = "#161b22"; });
    btn.addEventListener("mouseleave", () => { btn.style.background = "none"; });
    btn.addEventListener("click", () => { sendReaction(emoji); closePicker(); });
    return btn;
  }

  for (const emoji of QUICK_EMOJIS) {
    quickRow.appendChild(makeEmojiBtn(emoji, true));
  }

  // 全絵文字グリッドを構築（遅延）
  let gridBuilt = false;
  expandBtn.addEventListener("click", () => {
    const expanded = grid.style.display === "grid";
    if (expanded) {
      grid.style.display = "none";
      expandBtn.textContent = "もっと見る ▾";
    } else {
      if (!gridBuilt) {
        for (const emoji of EMOJIS) {
          grid.appendChild(makeEmojiBtn(emoji, false));
        }
        gridBuilt = true;
      }
      grid.style.display = "grid";
      expandBtn.textContent = "閉じる ▴";
    }
  });

  // ピッカー開閉
  addBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = picker.style.display !== "none";
    picker.style.display = isOpen ? "none" : "block";
  });
  document.addEventListener("click", (e) => {
    if (!picker.contains(e.target) && e.target !== addBtn) closePicker();
  });
  function closePicker() { picker.style.display = "none"; }

  // リアクションピルを作成・更新（count=0なら削除）
  function upsertPill(emoji, count) {
    const id = `pill-${[...emoji].map(c => c.codePointAt(0).toString(16)).join("-")}`;
    let pill = document.getElementById(id);
    if (count === 0) {
      pill?.remove();
      return;
    }
    if (!pill) {
      pill = document.createElement("button");
      pill.id = id;
      pill.style.cssText = "display:inline-flex; align-items:center; gap:0.4rem; padding:0.3rem 0.7rem; background:#0d1117; border:1px solid #30363d; border-radius:20px; color:#e6edf3; font-size:0.9rem; cursor:pointer; transition:border-color 0.2s, background 0.2s, box-shadow 0.2s;";
      pill.addEventListener("mouseenter", () => {
        if (!reacted.has(emoji)) pill.style.boxShadow = "0 0 0 3px rgba(88,166,255,0.12)";
      });
      pill.addEventListener("mouseleave", () => {
        if (!reacted.has(emoji)) pill.style.boxShadow = "none";
      });
      pill.addEventListener("click", () => sendReaction(emoji));
      list.insertBefore(pill, addBtn);
    }
    const active = reacted.has(emoji);
    pill.style.borderColor = active ? "#58a6ff" : "#30363d";
    pill.style.background = active ? "rgba(88,166,255,0.15)" : "#0d1117";
    pill.style.boxShadow = active ? "0 0 0 3px rgba(88,166,255,0.1)" : "none";
    pill.innerHTML = `<span>${emoji}</span><span style="font-size:0.78rem; color:${active ? "#58a6ff" : "#8b949e"}; font-family:'JetBrains Mono',monospace;">${count}</span>`;
  }

  // リアクション送信（トグル対応）
  async function sendReaction(emoji) {
    const removing = reacted.has(emoji);
    try {
      const res = await fetch(`/api/reactions?post=${encodeURIComponent(postId)}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ emoji, remove: removing }),
      });
      const data = await res.json();
      if (removing) {
        reacted.delete(emoji);
      } else {
        reacted.add(emoji);
      }
      localStorage.setItem(storageKey, JSON.stringify([...reacted]));
      upsertPill(emoji, data.count);
    } catch {}
  }

  // 初期ロード
  fetch(`/api/reactions?post=${encodeURIComponent(postId)}`)
    .then(r => r.json())
    .then(data => {
      for (const [emoji, count] of Object.entries(data)) {
        upsertPill(emoji, count);
      }
    })
    .catch(() => {});
</script>

<script define:vars={{ postId: post.id }}>
  // コメント機能
  const tokenStoreKey = `comment-tokens:${postId}`;
  const myTokens = JSON.parse(localStorage.getItem(tokenStoreKey) ?? "{}");

  const commentList = document.getElementById("comment-list");
  const commentCount = document.getElementById("comment-count");
  const commentForm = document.getElementById("comment-form");
  const authorInput = document.getElementById("comment-author");
  const contentInput = document.getElementById("comment-content");
  const submitBtn = document.getElementById("comment-submit-btn");
  const formError = document.getElementById("comment-form-error");

  function saveTokens() {
    localStorage.setItem(tokenStoreKey, JSON.stringify(myTokens));
  }

  function formatDate(iso) {
    const d = new Date(iso);
    return d.toLocaleDateString("ja-JP", { year: "numeric", month: "2-digit", day: "2-digit", hour: "2-digit", minute: "2-digit" });
  }

  function escapeHtml(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function renderComment(comment) {
    const isMine = !!myTokens[comment.id];
    const el = document.createElement("div");
    el.id = `comment-${comment.id}`;
    el.style.cssText = "padding: 1rem; border: 1px solid #30363d; border-radius: 8px; background: #161b22;";
    el.innerHTML = `
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem; gap: 0.5rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <span style="font-weight: 600; color: #e6edf3; font-size: 0.875rem;">${escapeHtml(comment.author)}</span>
          ${isMine ? '<span style="font-size: 0.7rem; color: #58a6ff; background: rgba(88,166,255,0.1); border: 1px solid rgba(88,166,255,0.3); border-radius: 4px; padding: 0.1rem 0.4rem;">自分</span>' : ""}
          ${comment.edited ? '<span style="font-size: 0.7rem; color: #8b949e;">(編集済み)</span>' : ""}
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <time style="font-size: 0.75rem; color: #8b949e; font-family: 'JetBrains Mono', monospace;">${formatDate(comment.timestamp)}</time>
          ${isMine ? `
            <button class="edit-btn" data-id="${comment.id}" style="padding: 0.2rem 0.5rem; background: none; border: 1px solid #30363d; border-radius: 4px; color: #8b949e; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; cursor: pointer;" onmouseenter="this.style.borderColor='#58a6ff';this.style.color='#58a6ff'" onmouseleave="this.style.borderColor='#30363d';this.style.color='#8b949e'">編集</button>
            <button class="delete-btn" data-id="${comment.id}" style="padding: 0.2rem 0.5rem; background: none; border: 1px solid #30363d; border-radius: 4px; color: #8b949e; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace; cursor: pointer;" onmouseenter="this.style.borderColor='#f85149';this.style.color='#f85149'" onmouseleave="this.style.borderColor='#30363d';this.style.color='#8b949e'">削除</button>
          ` : ""}
        </div>
      </div>
      <p class="comment-body" style="color: #c9d1d9; font-size: 0.875rem; line-height: 1.6; margin: 0; white-space: pre-wrap;">${escapeHtml(comment.content)}</p>
      ${isMine ? `
        <div class="edit-form" style="display: none; margin-top: 0.75rem;">
          <textarea class="edit-textarea" rows="3" style="width: 100%; padding: 0.5rem 0.75rem; background: #0d1117; border: 1px solid #58a6ff; border-radius: 6px; color: #e6edf3; font-size: 0.875rem; font-family: inherit; outline: none; resize: vertical; box-sizing: border-box;">${escapeHtml(comment.content)}</textarea>
          <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
            <button class="edit-save-btn" data-id="${comment.id}" style="padding: 0.3rem 0.75rem; background: #238636; border: 1px solid #2ea043; border-radius: 6px; color: #fff; font-size: 0.8rem; font-family: 'JetBrains Mono', monospace; cursor: pointer;">保存</button>
            <button class="edit-cancel-btn" style="padding: 0.3rem 0.75rem; background: none; border: 1px solid #30363d; border-radius: 6px; color: #8b949e; font-size: 0.8rem; font-family: 'JetBrains Mono', monospace; cursor: pointer;">キャンセル</button>
          </div>
        </div>
      ` : ""}
    `;

    // 編集ボタン
    el.querySelector(".edit-btn")?.addEventListener("click", () => {
      el.querySelector(".edit-form").style.display = "block";
      el.querySelector(".edit-btn").style.display = "none";
      el.querySelector(".delete-btn").style.display = "none";
    });

    // 編集キャンセル
    el.querySelector(".edit-cancel-btn")?.addEventListener("click", () => {
      el.querySelector(".edit-form").style.display = "none";
      el.querySelector(".edit-btn").style.display = "";
      el.querySelector(".delete-btn").style.display = "";
    });

    // 編集保存
    el.querySelector(".edit-save-btn")?.addEventListener("click", async (e) => {
      const id = e.target.dataset.id;
      const newContent = el.querySelector(".edit-textarea").value.trim();
      if (!newContent) return;
      const token = myTokens[id];
      try {
        const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}&id=${encodeURIComponent(id)}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, content: newContent }),
        });
        if (!res.ok) throw new Error();
        const updated = await res.json();
        el.querySelector(".comment-body").textContent = updated.content;
        el.querySelector(".edit-textarea").value = updated.content;
        el.querySelector(".edit-form").style.display = "none";
        el.querySelector(".edit-btn").style.display = "";
        el.querySelector(".delete-btn").style.display = "";
        // 「編集済み」バッジを追加
        if (!el.querySelector(".edited-badge")) {
          const badge = document.createElement("span");
          badge.className = "edited-badge";
          badge.textContent = "(編集済み)";
          badge.style.cssText = "font-size: 0.7rem; color: #8b949e;";
          el.querySelector(".edit-btn").before(badge, el.querySelector(".edit-btn").previousSibling);
        }
      } catch {
        alert("編集に失敗しました。");
      }
    });

    // 削除ボタン
    el.querySelector(".delete-btn")?.addEventListener("click", async (e) => {
      if (!confirm("このコメントを削除しますか？")) return;
      const id = e.target.dataset.id;
      const token = myTokens[id];
      try {
        const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}&id=${encodeURIComponent(id)}`, {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token }),
        });
        if (!res.ok) throw new Error();
        el.remove();
        delete myTokens[id];
        saveTokens();
        updateCount(-1);
      } catch {
        alert("削除に失敗しました。");
      }
    });

    return el;
  }

  let currentCount = 0;
  function updateCount(delta) {
    currentCount += delta;
    commentCount.textContent = `（${currentCount}件）`;
  }

  // コメント一覧を取得
  async function loadComments() {
    try {
      const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}`);
      const comments = await res.json();
      currentCount = comments.length;
      commentCount.textContent = `（${currentCount}件）`;
      commentList.innerHTML = "";
      if (comments.length === 0) {
        const empty = document.createElement("p");
        empty.id = "comment-empty";
        empty.style.cssText = "color: #8b949e; font-size: 0.875rem; text-align: center; padding: 1.5rem 0;";
        empty.textContent = "まだコメントはありません。最初のコメントを書いてみましょう！";
        commentList.appendChild(empty);
      } else {
        for (const c of comments) {
          commentList.appendChild(renderComment(c));
        }
      }
    } catch {}
  }

  // コメント送信
  commentForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const author = authorInput.value.trim();
    const content = contentInput.value.trim();
    if (!author || !content) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "送信中...";
    formError.style.display = "none";

    try {
      const res = await fetch(`/api/comments?post=${encodeURIComponent(postId)}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ author, content }),
      });
      const data = await res.json();
      if (!res.ok) {
        formError.textContent = data.error ?? "送信に失敗しました。";
        formError.style.display = "inline";
        return;
      }

      // トークンを保存
      myTokens[data.id] = data.token;
      saveTokens();

      // 空メッセージを削除
      document.getElementById("comment-empty")?.remove();

      commentList.appendChild(renderComment(data));
      updateCount(1);
      authorInput.value = "";
      contentInput.value = "";
    } catch {
      formError.textContent = "送信に失敗しました。";
      formError.style.display = "inline";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "送信";
    }
  });

  loadComments();
</script>
</BaseLayout>
