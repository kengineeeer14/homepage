---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="Blog | ken.log" description="学習・趣味のアウトプットブログ" meta={{ type: "blog", postCount: allPosts.length, allTags }}>
  <div style="padding: 2rem 0;">
    <p
      style="color: #58a6ff; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; margin-bottom: 0.5rem;"
    >
      $ ls ./blog/
    </p>
    <h1
      style="font-size: 2rem; font-weight: 700; color: #e6edf3; margin-bottom: 0.5rem;"
    >
      Blog
    </h1>
    <p id="post-count" style="color: #8b949e; margin-bottom: 2rem;">{allPosts.length} 記事</p>

    <!-- タグフィルター -->
    {
      allTags.length > 0 && (
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem;">
          <button class="tag-btn active" data-tag="">すべて</button>
          {allTags.map((tag) => (
            <button class="tag-btn" data-tag={tag}>#{tag}</button>
          ))}
        </div>
      )
    }

    <!-- 記事一覧 -->
    {
      allPosts.length === 0 ? (
        <p style="color: #8b949e; font-style: italic;">
          記事はまだありません。
        </p>
      ) : (
        <ul id="post-list" style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
          {allPosts.map((post) => (
            <li data-tags={JSON.stringify(post.data.tags)}>
              <a
                href={`/blog/${post.id}`}
                class="post-link"
                style="display: block; padding: 1.25rem; border: 1px solid #30363d; border-radius: 8px; text-decoration: none; background-color: #161b22; transition: border-color 0.2s;"
              >
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
                  <h2 style="font-size: 1rem; font-weight: 600; color: #e6edf3; margin: 0 0 0.375rem;">
                    {post.data.title}
                  </h2>
                  <time style="color: #8b949e; font-size: 0.8rem; font-family: 'JetBrains Mono', monospace; white-space: nowrap;">
                    {post.data.date.toISOString().slice(0, 10)}
                  </time>
                </div>
                <p style="color: #8b949e; font-size: 0.875rem; margin: 0 0 0.75rem; line-height: 1.6;">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
                    {post.data.tags.map((tag) => (
                      <span style="padding: 0.15rem 0.5rem; background-color: rgba(88,166,255,0.1); color: #58a6ff; border-radius: 4px; font-size: 0.75rem; font-family: 'JetBrains Mono', monospace;">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>

<style>
  .post-link:hover {
    border-color: #58a6ff !important;
  }

  .tag-btn {
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    cursor: pointer;
    background: none;
    border: 1px solid #30363d;
    color: #8b949e;
    font-family: inherit;
    transition: border-color 0.15s, color 0.15s;
  }
  .tag-btn:hover {
    border-color: #58a6ff;
    color: #58a6ff;
  }
  .tag-btn.active {
    border-color: #58a6ff;
    color: #58a6ff;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const items = document.querySelectorAll<HTMLLIElement>('#post-list li');
  const countEl = document.getElementById('post-count');

  function applyFilter(tag: string) {
    let visible = 0;
    items.forEach((item) => {
      const tags: string[] = JSON.parse(item.dataset.tags ?? '[]');
      const show = tag === '' || tags.includes(tag);
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (countEl) {
      countEl.textContent = tag === ''
        ? `${items.length} 記事`
        : `${visible} 記事（#${tag}）`;
    }

    buttons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tag === tag);
    });

    const url = new URL(window.location.href);
    if (tag) {
      url.searchParams.set('tag', tag);
    } else {
      url.searchParams.delete('tag');
    }
    history.replaceState(null, '', url.toString());
  }

  // ページ読み込み時にURLのtagパラメータを適用
  const initialTag = new URL(window.location.href).searchParams.get('tag') ?? '';
  applyFilter(initialTag);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.tag ?? ''));
  });
</script>
